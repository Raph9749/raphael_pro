# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/raphael_pro
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/raphael_pro_test

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=Raphael Pro
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# S3 / File Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
S3_BUCKET_NAME=raphael-pro-documents

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@raphael-pro.fr

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
